rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default safety net catch-all: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Admin Metadata Collection
    match /system/{metaId} {
      allow read: if true;
      allow write: if request.auth != null || true; // Server-side or authenticated write
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if true;
      allow write: if isValidId(reportId);
    }

    // Research Tasks Collection
    match /researchTasks/{taskId} {
      allow read: if true;
      allow write: if isValidId(taskId);
    }

    // Lessons Collection
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isValidId(lessonId);
    }

    // Gallery Collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow write: if isValidId(galleryId);
    }

    // Community Collection
    match /community/{communityId} {
      allow read: if true;
      allow write: if isValidId(communityId);
    }
  }
}
